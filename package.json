{
  "name": "vocanote-template-builder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch --tsconfig server/tsconfig.json server/src/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc -p server/tsconfig.json && vite build --config client/vite.config.ts",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "test": "vitest run --config server/vitest.config.ts",
    "test:watch": "vitest --config server/vitest.config.ts"
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "openai": "^6.39.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
